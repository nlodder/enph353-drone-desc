    <xacro:property name="j_rotor_rl_parent_link" value="link_motor_rl" />

    <xacro:property name="j_rotor_joint_axis" value="0 0 1" />
    <xacro:property name="j_rotor_lim_effort" value="10" />
    <xacro:property name="j_rotor_lim_vel" value="10" />


    <xacro:macro name="motor_link_joint"
        params="location inert_xyz inert_rpy vis_xyz vis_rpy mesh child_orig_xyz child_orig_rpy">
        <link name="link_motor_${location}">
            <inertial>
                <origin xyz="${inert_xyz}" rpy="${inert_rpy}" />
                <mass value="${l_motor_mass}" />
                <inertia ixx="${l_motor_ixx}" ixy="${l_motor_ixy}" ixz="${l_motor_ixz}"
                    iyy="${l_motor_iyy}" iyz="${l_motor_iyz}" izz="${l_motor_izz}" />
            </inertial>
            <visual>
                <origin xyz="${vis_xyz}" rpy="${vis_rpy}" />
                <geometry>
                    <mesh filename="${mesh}" />
                </geometry>
                <material name="link_motor_${location}_material">
                    <color rgba="${l_motor_color}" />
                </material>
            </visual>
            <collision>
                <origin xyz="${vis_xyz}" rpy="${vis_rpy}" />
                <geometry>
                    <mesh filename="${mesh}" />
                </geometry>
            </collision>
        </link>

        <joint name="joint_motor_${location}" type="fixed">
            <origin xyz="${child_orig_xyz}" rpy="${child_orig_rpy}" />
            <parent link="${j_motor_parent_link}" />
            <child link="link_motor_${location}" />
            <axis xyz="${j_motor_joint_axis}" />
            <limit effort="${j_motor_lim_effort}" velocity="${j_motor_lim_vel}" />
        </joint>
    </xacro:macro>


    <xacro:macro name="rotor_link_joint"
        params="location inert_xyz inert_rpy vis_xyz vis_rpy mesh parent_link child_link orig_xyz orig_rpy">

        <link name="link_rotor_${location}">
            <inertial>
                <origin xyz="${inert_xyz}" rpy="${inert_rpy}" />
                <mass value="${l_rotor_mass}" />
                <inertia ixx="${l_rotor_ixx}" ixy="${l_rotor_ixy}" ixz="${l_rotor_ixz}"
                    iyy="${l_rotor_iyy}" iyz="${l_rotor_iyz}" izz="${l_rotor_izz}" />
            </inertial>
            <visual>
                <origin xyz="${vis_xyz}" rpy="${vis_rpy}" />
                <geometry>
                    <mesh filename="${mesh}" />
                </geometry>
                <material name="link_rotor_${location}_material">
                    <color rgba="${l_rotor_color}" />
                </material>
            </visual>
            <collision>
                <origin xyz="${vis_xyz}" rpy="${vis_rpy}" />
                <geometry>
                    <mesh filename="${mesh}" />
                </geometry>
            </collision>
        </link>

        <joint name="joint_rotor_${location}" type="fixed">
            <origin xyz="${orig_xyz}" rpy="${orig_rpy}" />
            <parent link="${parent_link}" />
            <child link="${child_link}" />
            <axis xyz="${j_rotor_joint_axis}" />
            <limit effort="${j_rotor_lim_effort}" velocity="${j_rotor_lim_vel}" />
        </joint>
    </xacro:macro>

    <!-- MOTOR JOINTS -->
    <xacro:motor_link_joint location="fl" inert_xyz="${l_motor_fl_inert_orig_xyz}"
        inert_rpy="${l_motor_fl_inert_orig_rpy}" vis_xyz="${l_motor_fl_vis_coll_orig_xyz}"
        vis_rpy="${l_motor_fl_vis_coll_orig_rpy}" mesh="${l_motor_fl_mesh}"
        child_orig_xyz="${j_motor_fl_orig_xyz}" child_orig_rpy="${j_motor_fl_orig_rpy}" />

    <xacro:motor_link_joint location="fr" inert_xyz="${l_motor_fr_inert_orig_xyz}"
