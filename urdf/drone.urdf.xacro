        vis_rpy="${l_motor_fr_vis_coll_orig_rpy}" mesh="${l_motor_fr_mesh}"
        child_orig_xyz="${j_motor_fr_orig_xyz}" child_orig_rpy="${j_motor_fr_orig_rpy}" />

