    <joint name="joint_imu" type="fixed">
        <origin xyz="0 0 0.005" rpy="0 0 0" />
        <parent link="link_drone_body" />
        <child link="link_imu" />
    </joint>

    <joint name="joint_front_camera" type="fixed">
        <origin xyz="0.0197234 -0.0 0.02" rpy="-0 -0 -0" />
        <parent link="link_drone_body" />
        <child link="link_front_camera" />
    </joint>

    <joint name="joint_left_camera" type="fixed">
        <origin xyz="0.0 0.0197234 0.02" rpy="-0 -0 1.570796" />
