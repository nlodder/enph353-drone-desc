        </inertial>
        <visual>
            <origin xyz="-0.000276567 -8.03059e-05 0" rpy="0 -0 1.5708" />
            <geometry>
                <mesh filename="package://drone_desc/meshes/link_drone_body.stl" />
            </geometry>
            <material name="link_drone_body_material">
                <color rgba="1 0 0 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="-0.000276567 -8.03059e-05 0" rpy="0 -0 1.5708" />
            <geometry>
                <mesh filename="package://drone_desc/meshes/link_drone_body.stl" />
            </geometry>
        </collision>
    </link>

